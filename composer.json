{
  "name": "wp-claude-lab/tooling",
  "description": "PHP linting and static analysis tooling for WordPress development",
  "version": "1.0.0",
  "type": "project",
  "require": {
    "php": ">=8.1"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    }
  },
  "require-dev": {
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "phpstan/extension-installer": "^1.4",
    "phpunit/phpunit": "^10.0",
    "brain/monkey": "^2.6",
    "mockery/mockery": "^1.6",
    "roave/security-advisories": "dev-latest"
  },
  "scripts": {
    "php-format": "vendor/bin/phpcbf --standard=./config/phpcs/phpcs.xml.dist --report-summary --report-source",
    "php-lint": "vendor/bin/phpcs --standard=./config/phpcs/phpcs.xml.dist",
    "php-compatibility": "vendor/bin/phpcs --standard=PHPCompatibilityWP --runtime-set testVersion 8.1",
    "phpstan": "vendor/bin/phpstan analyse -c config/phpstan/phpstan.neon.dist --memory-limit=1G",
    "phpstan:baseline": "vendor/bin/phpstan analyse -c config/phpstan/phpstan.neon.dist --memory-limit=1G --generate-baseline=config/phpstan/phpstan-baseline.neon",
    "test": "vendor/bin/phpunit",
    "test:hooks": "bash -c 'command -v bats >/dev/null 2>&1 && bats tests/hooks/ || echo \"[skip] bats-core が見つかりません。brew install bats-core または npm i -g bats で導入してください\"'"
  }
}
